msgid "plugins.generic.cinfo.displayName"
msgstr "C-info Plugin"

msgid "plugins.generic.cinfo.description"
msgstr "Integrate C-info icon to abstract pages."

msgid "plugins.generic.cinfo.manager.settings.description"
msgstr "Create the code for the C-info icon using the form on the service homepage. Paste the generated C-info icon code into the text box below and save."

msgid "plugins.generic.cinfo.manager.settings.cinfoButtonCode"
msgstr "C-info icon code"

msgid "plugins.generic.cinfo.manager.settings.cinfoButtonCodeRequired"
msgstr "C-info icon code is required"

msgid "plugins.generic.cinfo.manager.settings.cinfoPerArticle"
msgstr "The C-info icon is added only to selected articles"

msgid "plugins.generic.cinfo.manager.settings.cinfoPerArticleDescription"
msgstr "When the plugin is enabled, the C-info icon is added to all content by default. If you want to attach C-info only to specific selected articles/books, enable the option below. In that case, the icon can be added through the license settings for each article/book."

msgid "plugins.generic.cinfo.cinfoLabel.name"
msgstr "C-info"

msgid "plugins.generic.cinfo.cinfoLabel.description"
msgstr "Add C-info icon"

